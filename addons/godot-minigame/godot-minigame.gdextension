[configuration]

entry_symbol = "godot_minigame_library_init"
compatibility_minimum = "4.1"

[libraries]
; Relative paths ensure that our GDExtension can be placed anywhere in the project directory.
macos = "./bin/macos/libgodot-minigame.macos.dylib"
windows.x86_64 = "./bin/windows/godot-minigame.windows.x86_64.dll"
linux.x86_64 = "./bin/linux/libgodot-minigame.linux.x86_64.so"